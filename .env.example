# ============================================
# Personal AI Assistant - Environment Configuration Example
# ============================================
# Instructions:
# 1. Copy this file to .env
# 2. Fill in your actual configuration values
# 3. Do NOT commit .env to version control
# ============================================

# --------------------------------------------
# DeepSeek API Configuration
# --------------------------------------------
# Get API key: https://platform.deepseek.com/
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-your-deepseek-api-key-here
OPENAI_MODEL=deepseek-chat
OPENAI_TEMPERATURE=0.7

# --------------------------------------------
# Email Configuration (SMTP) - Optional
# --------------------------------------------
# For QQ Mail:
#   EMAIL_SMTP_SERVER=smtp.qq.com
#   EMAIL_SMTP_PORT=587
#   EMAIL_SENDER=your-email@qq.com
#   EMAIL_PASSWORD=your-smtp-password (authorization code, not login password)
#
# Leave blank to skip email sending (demo mode)
EMAIL_SMTP_SERVER=smtp.qq.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your-email@qq.com
EMAIL_PASSWORD=your-authorization-code

# --------------------------------------------
# Application Settings
# --------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Asia/Shanghai

# --------------------------------------------
# Feature Toggles
# --------------------------------------------
EMAIL_NOTIFICATION_ENABLED=true
CALENDAR_MAX_EVENTS=50
CONFLICT_CHECK_HOURS=2
