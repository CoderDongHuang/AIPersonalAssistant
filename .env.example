# ============================================
# Personal AI Assistant - 环境变量配置示例
# ============================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 填入你的实际配置值
# 3. 不要将 .env 文件提交到版本控制系统
# ============================================

# --------------------------------------------
# OpenAI API 配置
# --------------------------------------------
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# 使用的模型: gpt-4-turbo, gpt-4, gpt-3.5-turbo
OPENAI_MODEL=gpt-4-turbo

# 温度参数 (0.0-1.0): 越高越有创造性，越低越稳定
OPENAI_TEMPERATURE=0.7

# --------------------------------------------
# Microsoft Graph API 配置
# --------------------------------------------
# Azure应用注册获取: https://portal.azure.com/#blade/Microsoft_AAD_IAM/ActiveDirectoryMenuBlade/RegisteredApps
AZURE_CLIENT_ID=your-azure-client-id-here

# 租户ID (个人账号使用common即可)
AZURE_TENANT_ID=common

# --------------------------------------------
# 应用配置
# --------------------------------------------
# 运行环境: development, production
APP_ENV=development

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 默认时区
DEFAULT_TIMEZONE=Asia/Shanghai

# --------------------------------------------
# 数据库配置 (可选，用于生产环境的状态持久化)
# --------------------------------------------
# PostgreSQL 连接字符串
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_assistant

# --------------------------------------------
# 功能开关
# --------------------------------------------
# 是否启用邮件通知
EMAIL_NOTIFICATION_ENABLED=true

# 日历查询最大事件数
CALENDAR_MAX_EVENTS=50

# 冲突检测时间范围（小时）
CONFLICT_CHECK_HOURS=2
