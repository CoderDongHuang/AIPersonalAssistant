# ============================================
# Personal AI Assistant - Environment Configuration Example
# ============================================
# Instructions:
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in your actual configuration values
# 3. Do NOT commit .env to version control
# ============================================

# --------------------------------------------
# DeepSeek API Configuration (Primary LLM)
# --------------------------------------------
# Get API key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# --------------------------------------------
# OpenAI-Compatible Base URL
# --------------------------------------------
# Default: DeepSeek. Change to use other compatible providers.
OPENAI_BASE_URL=https://api.deepseek.com/v1

# --------------------------------------------
# Email Configuration (SMTP) - Optional
# --------------------------------------------
# For QQ Mail:
#   EMAIL_SMTP_SERVER=smtp.qq.com
#   EMAIL_SMTP_PORT=587
#   EMAIL_SENDER=your-email@qq.com
#   EMAIL_PASSWORD=your-smtp-auth-code (NOT login password!)
#
# For 163 Mail:
#   EMAIL_SMTP_SERVER=smtp.163.com
#   EMAIL_SMTP_PORT=587
#
# Leave blank to skip email sending (graceful degradation)
EMAIL_SMTP_SERVER=smtp.qq.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your-email@qq.com
EMAIL_PASSWORD=your-authorization-code

# --------------------------------------------
# Application Settings
# --------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Asia/Shanghai

# --------------------------------------------
# Feature Toggles
# --------------------------------------------
EMAIL_NOTIFICATION_ENABLED=true
CALENDAR_MAX_EVENTS=50
CONFLICT_CHECK_HOURS=2
